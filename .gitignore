*~

# OS
.DS_Store
Thumbs.db

# Results and generated outputs
# Ignore everything in 5_results/ but allow specific files/directories
5_results/**
# Keep only template files and example directory in results
!5_results/models_evaluation_selection_template.json
!5_results/example/
!5_results/example/**

# Model weights and checkpoints
*.pth
*.h5
*.ckpt
*.pkl
*.pb
*.onnx
3_model/base_model_architectures/*.pth
# Allow PKL files in example directory (training data for plots)
!5_results/example/**/*.pkl

# Image files (all formats)
*.png
*.jpg
*.jpeg
*.tif
*.tiff
*.bmp
*.gif
*.svg
*.webp
*.ico

# Allow images in example directory
!5_results/example/**/*.png
!5_results/example/**/*.jpg
!5_results/example/**/*.jpeg
!5_results/example/**/*.svg

# Data directory - exclude everything except upload script
1_data/*
!1_data/data_upload_script/
!1_data/data_upload_script/**

# Large CSV result files are already excluded by 5_results/** above
# (No need for separate pattern since entire directory is ignored)

# Logs
*.log
terminal_output.txt

# WandB
wandb/

# Temporary files
*.tmp
*.temp
*.bak

/paper_temp/